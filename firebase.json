{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/app", "destination": "/app.html" },
      { "source": "/app/**", "destination": "/app.html" },
      { "source": "/login", "destination": "/login.html" },
      { "source": "/login/**", "destination": "/login.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  }
}
